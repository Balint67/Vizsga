node_modules/
npm-debug.log
yarn-error.log

# --- VS Code ---
# Ha te esetleg VS Code-ot használsz, akkor ezt is tedd bele,
# hogy te se szemeteld tele az ő gépét a te beállításaiddal:
.vscode/